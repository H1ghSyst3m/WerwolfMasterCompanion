{
  "name": "werwolf-master-companion",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently -k -n web,server -c cyan,magenta \"npm run dev -- --host 0.0.0.0\" \"npm run server:dev\"",
    "server:dev": "tsx watch server/index.ts",
    "server:start": "tsx server/index.ts",
    "test": "vitest run",
    "build": "tsc -b && vite build",
    "build:app": "tsc -b && vite build --mode capacitor",
    "cap:sync": "npm run build:app && npx cap sync",
    "cap:android": "npm run build:app && npx cap sync android && npx cap open android",
    "cap:ios": "npm run build:app && npx cap sync ios && npx cap open ios",
    "cap:apk:debug": "npm run build:app && npx cap sync android && cd android && gradlew assembleDebug",
    "cap:apk:release": "npm run build:app && npx cap sync android && cd android && gradlew assembleRelease",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor/core": "^8.3.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsx": "^4.21.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.1",
    "vitest": "^4.1.5"
  }
}
